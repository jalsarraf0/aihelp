# GitHub repository to register this runner against
REPO_URL=https://github.com/jalsarraf0/aihelp
RUNNER_SCOPE=repo

# Runner identity and labels (workflow runs-on must match)
RUNNER_NAME=aihelp-linux-docker
LABELS=self-hosted,linux,x64,aihelp
RUNNER_WORKDIR=/_work
RUNNER_GROUP=Default

# Required: PAT with repo administration rights for runner registration
ACCESS_TOKEN=ghp_replace_me

# Runner persistence/reuse settings
CONFIGURED_ACTIONS_RUNNER_FILES_DIR=/runner-state
DISABLE_AUTOMATIC_DEREGISTRATION=true
RUN_AS_ROOT=true
RANDOM_RUNNER_SUFFIX=false

# Optional
# GITHUB_HOST=github.com
# START_DOCKER_SERVICE=false
